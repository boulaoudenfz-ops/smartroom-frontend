# ─── Runtime secrets (never commit this file) ────────────────────────────────
# Copy this file to .env.production on the server and fill in real values.
# Variables without NEXT_PUBLIC_ prefix are server-side only (safe).
# Variables with NEXT_PUBLIC_ prefix are inlined into the client bundle at build time.

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV=production

# ── Server port (cPanel overrides this automatically; keep 3000 as fallback) ──
PORT=3000

# ── Laravel Backend API ───────────────────────────────────────────────────────
# Server-side API base URL (not exposed to browser — used by rewrites / server components)
API_BASE_URL=http://backend.seedalotour.shop/api

# Client-side API base URL (exposed to browser — inlined at build time)
NEXT_PUBLIC_API_URL=http://backend.seedalotour.shop/api

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign/verify auth tokens (keep private)
AUTH_SECRET=replace_with_a_long_random_string_min_32_chars

# ── Optional: Anthropic AI (for /api/chat route) ─────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: Server Actions encryption key (required for multi-instance) ─────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
